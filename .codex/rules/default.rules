# Production-safe baseline for Codex command approvals.
# Policy: allow read-only inspection commands, prompt for mutating/risky commands.

# Read-only / low-risk commands
prefix_rule(pattern=["awk"], decision="allow")
prefix_rule(pattern=["basename"], decision="allow")
prefix_rule(pattern=["cat"], decision="allow")
prefix_rule(pattern=["cut"], decision="allow")
prefix_rule(pattern=["date"], decision="allow")
prefix_rule(pattern=["diff"], decision="allow")
prefix_rule(pattern=["dirname"], decision="allow")
prefix_rule(pattern=["echo"], decision="allow")
prefix_rule(pattern=["env"], decision="allow")
prefix_rule(pattern=["file"], decision="allow")
prefix_rule(pattern=["find"], decision="allow")
prefix_rule(pattern=["head"], decision="allow")
prefix_rule(pattern=["id"], decision="allow")
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["printenv"], decision="allow")
prefix_rule(pattern=["printf"], decision="allow")
prefix_rule(pattern=["pwd"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["sed"], decision="allow")
prefix_rule(pattern=["sort"], decision="allow")
prefix_rule(pattern=["stat"], decision="allow")
prefix_rule(pattern=["tail"], decision="allow")
prefix_rule(pattern=["tr"], decision="allow")
prefix_rule(pattern=["uname"], decision="allow")
prefix_rule(pattern=["uniq"], decision="allow")
prefix_rule(pattern=["wc"], decision="allow")
prefix_rule(pattern=["which"], decision="allow")
prefix_rule(pattern=["whoami"], decision="allow")

# High-risk shell wrappers and package managers
prefix_rule(pattern=["bash", "-lc"], decision="prompt")
prefix_rule(pattern=["/bin/bash", "-lc"], decision="prompt")
prefix_rule(pattern=["brew"], decision="prompt")
prefix_rule(pattern=["codex", "mcp"], decision="prompt")
prefix_rule(pattern=["conda"], decision="prompt")
prefix_rule(pattern=["dnf"], decision="prompt")
prefix_rule(pattern=["npm"], decision="prompt")
prefix_rule(pattern=["npx"], decision="prompt")
prefix_rule(pattern=["pacman"], decision="prompt")
prefix_rule(pattern=["pip"], decision="prompt")
prefix_rule(pattern=["pip3"], decision="prompt")
prefix_rule(pattern=["pipx"], decision="prompt")
prefix_rule(pattern=["pnpm"], decision="prompt")
prefix_rule(pattern=["python", "-m", "pip"], decision="prompt")
prefix_rule(pattern=["python3", "-m", "pip"], decision="prompt")
prefix_rule(pattern=["uv"], decision="prompt")
prefix_rule(pattern=["yarn"], decision="prompt")

# Mutating filesystem and git commands require confirmation
prefix_rule(pattern=["cp"], decision="prompt")
prefix_rule(pattern=["git", "add"], decision="prompt")
prefix_rule(pattern=["git", "commit"], decision="prompt")
prefix_rule(pattern=["mkdir"], decision="prompt")
prefix_rule(pattern=["mv"], decision="prompt")
prefix_rule(pattern=["rm", "-f"], decision="prompt")
prefix_rule(pattern=["rm", "-rf"], decision="prompt")
prefix_rule(pattern=["touch"], decision="prompt")
